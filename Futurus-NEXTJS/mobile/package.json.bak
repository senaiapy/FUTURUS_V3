{
  "name": "futurus-mobile",
  "version": "1.0.9",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "erase": "rm -rf node_modules && rm -rf ios && rm -rf android && rm -rf .expo",
    "--------ANDROID--------": "--------ANDROID--------",
    "apk-install": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "apk": "cd android && ./gradlew assembleDebug && cd ..",
    "apk-release": "cd android && ./gradlew assembleRelease && cd ..",
    "release-ios-ipa": "APP_ENV=production EXPO_NO_DOTENV=1 npx eas build --profile adhoc --platform ios",
    "release-android-apk": "pnpm cglad && pnpm apk-release && pnpm apk-install",
    "release-android-apk-fast": "pnpm apk-release && pnpm apk-install",
    "build": "pnpm android --variant release",
    "builds": "cross-env EXPO_NO_DOTENV=1 expo run:android --variant release",
    "bundle": "cd android && cross-env APP_ENV=development ./gradlew bundleRelease",
    "bundles": "cd android && cross-env EXPO_NO_DOTENV=1 ./gradlew bundleRelease",
    "publish:android": "npx eas submit --platform android",
    "--------IOS--------": "--------IOS--------",
    "build-ios": "APP_ENV=production npx eas build --platform ios --local",
    "builds-ios": "cross-env APP_ENV=production EXPO_NO_DOTENV=1 expo run:ios --configuration Release -d",
    "ipa:release": "APP_ENV=production EXPO_NO_DOTENV=1 npx eas build --profile adhoc --platform ios --local",
    "publish:ios": "npx eas submit --platform ios",
    "ios:local-ipa": "APP_ENV=production EXPO_NO_DOTENV=1 npx eas build --profile adhoc --platform ios --local",
    "-----------------": "-----------------",
    "debug-release-adb": "adb logcat -c && adb shell monkey -p com.futurus.development 1 && adb logcat | grep -E \"ReactNativeJS|ExpoModules|futurus|Error|FATAL|Exception\"",
    "pre-release": "cd patches && ./patchRelease.sh && cd ..",
    "pods": "cd ios && pod install && cd ..",
    "cnode": "rm -rf node_modules",
    "cplat": "rm -rf android && rm -rf ios",
    "cglad": "cd android && rm -rf app/.cxx && rm -rf app/build && ./gradlew clean && cd ..",
    "node": "rm -rf node_modules",
    "my-eas": "eas whoami",
    "eas-signin": "npx eas credentials",
    "eas-install": "npm install -g eas-cli",
    "eas-create": "npx create-expo-app --template bare-minimum",
    "eas-login": "npx eas login",
    "eas-init": "eas init --id d44e36a3-227b-4037-aff3-021b83f55c1e",
    "eas-config-build": "npx eas build:configure",
    "eas-config-update": "npx eas update:configure",
    "expo-fix": "npx expo install --fix",
    "cleanp": "npx react-native-clean-project",
    "check": "npx expo install --check ",
    "clean": "npx expo prebuild --clean",
    "fix": "npx expo install --fix",
    "starts": "cross-env EXPO_NO_DOTENV=1 expo start --clean-cache",
    "==========": "================",
    "start": "cross-env EXPO_NO_DOTENV=1 expo start",
    "prebuild": "cross-env EXPO_NO_DOTENV=1 pnpm expo prebuild",
    "android": "cross-env EXPO_NO_DOTENV=1 expo run:android",
    "ios": "cross-env EXPO_NO_DOTENV=1 expo run:ios",
    "ios:device": "cross-env EXPO_NO_DOTENV=1 expo run:ios -d",
    "ios:release": "cross-env APP_ENV=production EXPO_NO_DOTENV=1 expo run:ios --configuration Release -d",
    "ios:sim": "cross-env EXPO_NO_DOTENV=1 npx expo run:ios --device 'iPhone 16 Simulator (18.1)'",
    "web": "cross-env EXPO_NO_DOTENV=1 expo start --web",
    "web:export": "cross-env APP_ENV=production EXPO_NO_DOTENV=1 expo export --platform web",
    "web:export:staging": "cross-env APP_ENV=staging EXPO_NO_DOTENV=1 expo export --platform web",
    "web:serve": "npx serve dist",
    "xcode": "xed -b ios",
    "doctor": "npx expo-doctor@latest",
    "preinstall": "npx only-allow pnpm",
    "start:staging": "cross-env APP_ENV=staging pnpm run start",
    "prebuild:staging": "cross-env APP_ENV=staging pnpm run prebuild",
    "prebuild:development": "cross-env APP_ENV=development pnpm run prebuild",
    "android:staging": "cross-env APP_ENV=staging pnpm run android",
    "ios:staging": "cross-env APP_ENV=staging pnpm run ios",
    "start:production": "cross-env APP_ENV=production pnpm run start",
    "prebuild:production": "cross-env APP_ENV=production pnpm run prebuild",
    "android:production": "cross-env APP_ENV=production pnpm run android",
    "ios:production": "cross-env APP_ENV=production pnpm run ios",
    "build:development:ios": "cross-env APP_ENV=development EXPO_NO_DOTENV=1 eas build --profile development --platform ios",
    "build:development:android": "cross-env APP_ENV=development EXPO_NO_DOTENV=1 eas build --profile development --platform android ",
    "build:staging:ios": "cross-env APP_ENV=staging EXPO_NO_DOTENV=1 eas build --profile staging --platform ios",
    "build:staging:android": "cross-env APP_ENV=staging EXPO_NO_DOTENV=1 eas build --profile staging --platform android ",
    "build:production:ios": "cross-env APP_ENV=production EXPO_NO_DOTENV=1 eas build --profile production --platform ios",
    "build:production:android": "cross-env APP_ENV=production EXPO_NO_DOTENV=1 eas build --profile production --platform android ",
    "prepare": "husky",
    "app-release": "cross-env SKIP_BRANCH_PROTECTION=true np --no-publish --no-cleanup --no-release-draft",
    "version": "pnpm run prebuild && git add .",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc  --noemit",
    "lint:translations": "eslint ./src/translations/ --fix --ext .json  ",
    "test": "jest",
    "check-all": "pnpm run lint && pnpm run type-check && pnpm run lint:translations && pnpm run test",
    "test:ci": "pnpm run test --coverage",
    "test:watch": "pnpm run test --watch",
    "install-maestro": "curl -Ls 'https://get.maestro.mobile.dev' | bash",
    "e2e-test": "maestro test .maestro/ -e APP_ID=com.pyfoundation.development",
    "+++++++++  EAS  ++++++++++++": "++++++++++++++++++++++",
    "my": "eas whoami",
    "eas:signin": "npx eas credentials",
    "eas:install": "npm install -g eas:cli",
    "eas:create": "npx create-expo-app --template bare-minimum",
    "eas:login": "npx eas login",
    "eas:config-update": "npx eas update:configure",
    "eas:config-build": "npx eas build:configure",
    "eas:build:android": "npx eas build --platform android --local",
    "eas:build-android-local": "APP_ENV=production EXPO_NO_DOTENV=1 npx eas build --profile production --platform android --local",
    "build:ios": "APP_ENV=production npx eas build --platform ios --local",
    "build:all": "APP_ENV=production npx eas build --platform all",
    "update:preview": "npx eas update --branch preview --message \"Updating Preview\"",
    "update:production": "npx eas update --branch production --message \"Updating Production\"",
    "submit:android": "npx eas submit --platform android",
    "submit:ios": "npx eas submit --platform ios",
    "+++++++++EAS  ++++++++++++": "++++++++++++++++++++++",
    "device:list": "xcrun xctrace list devices",
    "android-unsigned": "cp -av sign_header/AndroidManifest.xml.unsigned android/app/src/main/AndroidManifest.xml",
    "android-signed": "cp -av sign_header/AndroidManifest.xml.signed android/app/src/main/AndroidManifest.xml",
    "ios-unsigned": "cp -av sign_header/Expo.plist.unsigned ios/FuturusPYApp/Supporting/Expo.plist",
    "ios-signed": "cp -av sign_header/Expo.plist.signed ios/FuturusPYApp/Supporting/Expo.plist"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@gorhom/bottom-sheet": "^5.1.0",
    "@hookform/resolvers": "^3.9.1",
    "@react-navigation/drawer": "^7.1.6",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.59.20",
    "app-icon-badge": "^0.1.2",
    "axios": "^1.7.9",
    "expo": "~55.0.0",
    "expo-build-properties": "~55.0.9",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.8",
    "expo-dev-client": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-image": "~55.0.5",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-router": "~55.0.3",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "i18next": "^24.1.0",
    "lodash.memoize": "^4.1.2",
    "lucide-react-native": "^0.546.0",
    "moti": "^0.30.0",
    "nativewind": "^4.1.23",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "^4.1.2",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^15.1.4",
    "react-native": "0.83.2",
    "react-native-drawer-layout": "^4.1.3",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-flash-message": "^0.4.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "^1.18.0",
    "react-native-mmkv": "~3.2.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-restart": "0.0.27",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "~15.15.3",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.21.0",
    "react-query-kit": "^3.3.0",
    "tailwind-variants": "^0.3.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@dev-plugins/react-query": "^0.4.0",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.21.0",
    "@expo/config": "~55.0.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/i18n-js": "^3.8.9",
    "@types/invariant": "^2.2.37",
    "@types/jest": "^29.5.14",
    "@types/lodash.memoize": "^4.1.9",
    "@types/react": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.21.0",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^3.8.3",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "eslint-plugin-testing-library": "^7.1.1",
    "eslint-plugin-unicorn": "^57.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-expo": "~55.0.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^15.4.3",
    "np": "^10.1.0",
    "prettier": "^3.5.1",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "3.4.17",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyfoundation/react-native-template-pyfoundation.git"
  },
  "packageManager": "pnpm@10.28.0",
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-restart"
        ]
      }
    },
    "install": {
      "exclude": [
        "eslint-config-expo"
      ]
    }
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "unrs-resolver"
    ]
  }
}
