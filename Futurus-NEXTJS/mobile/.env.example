# Application Environment (development | preview | production)
EXPO_PUBLIC_APP_ENV=development

# API Configuration
# Set to 'next' for NestJS backend (port 3001) or 'laravel' for Laravel backend (port 8080)
EXPO_PUBLIC_API=laravel

# API URLs
# Next.js Backend (NestJS): http://localhost:3001/api
# Laravel Backend: http://localhost:8080/api
# Change EXPO_PUBLIC_API_URL to the correct backend URL below:

# For Laravel backend (currently active):
EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/api

# For Next.js backend (if switching back):
# EXPO_PUBLIC_API_URL=http://localhost:3001/api

# Example Variables
EXPO_PUBLIC_VAR_NUMBER=10
EXPO_PUBLIC_VAR_BOOL=true

# Build-time only secrets (no EXPO_PUBLIC prefix - NOT accessible in src folder)
SECRET_KEY=
APP_BUILD_ONLY_VAR=
EXPO_PUBLIC_APP_VERSION="1.0.9-04032026-15:07"
EXPO_PUBLIC_BUNDLE_ID="com.xxx"

# ─── Solana Blockchain Configuration ──────────────────────────────────────────
EXPO_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"
EXPO_PUBLIC_SOLANA_CLUSTER="devnet"
EXPO_PUBLIC_PREDICTION_PROGRAM_ID="your-program-id-here"
EXPO_PUBLIC_FUT_MINT="your-fut-mint-address-here"
EXPO_PUBLIC_COIN_NAME=""
EXPO_PUBLIC_APP_NAME=""