{
  "name": "futurus-mobile",
  "version": "1.1.3",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "main": "expo-router/entry",
  "scripts": {
    "build-production": "rm -rf android && pnpm run prebuild:production",
    "build-apk": "cd android && ./gradlew assembleRelease bundleRelease",
    "bundles": "cd android && cross-env EXPO_NO_DOTENV=1 ./gradlew bundleRelease",
    "start:android": "pnpm clean && pnpm android",
    "start": "npx expo start -c",
    "prebuild": "pnpm npx expo prebuild",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "web": "npx expo start --web",
    "xcode": "xed -b ios",
    "doctor": "npx expo-doctor@latest",
    "preinstall": "npx only-allow pnpm",
    "+++++++++  EAS  ++++++++++++": "++++++++++++++++++++++",
    "my": "eas whoami",
    "eas:signin": "npx eas credentials",
    "eas:install": "npm install -g eas:cli",
    "eas:create": "npx create-expo-app --template bare-minimum",
    "eas:login": "npx eas login",
    "eas:config-update": "npx eas update:configure",
    "eas:config-build": "npx eas build:configure",
    "eas:build:android": "npx eas build --platform android --local",
    "eas:build-android-local": "APP_ENV=production EXPO_NO_DOTENV=1 npx eas build --profile production --platform android --local",
    "build:ios": "APP_ENV=production npx eas build --platform ios --local",
    "build:all": "APP_ENV=production npx eas build --platform all",
    "update:preview": "npx eas update --branch preview --message \"Updating Preview\"",
    "update:production": "npx eas update --branch production --message \"Updating Production\"",
    "submit:android": "npx eas submit --platform android",
    "submit:ios": "npx eas submit --platform ios",
    "+++++++++EAS  ++++++++++++": "++++++++++++++++++++++",
    "device:list": "xcrun xctrace list devices",
    "debug-release-adb": "adb logcat -c && adb shell monkey -p com.futurus.development 1 && adb logcat | grep -E \"ReactNativeJS|ExpoModules|futurus|Error|FATAL|Exception\"",
    "cleanp": "npx react-native-clean-project",
    "check": "npx expo install --check ",
    "clean": "npx expo prebuild --clean",
    "fix": "npx expo install --fix",
    "erase": "rm -rf node_modules && rm -rf ios && rm -rf android && rm -rf .expo",
    "--------ANDROID--------": "--------ANDROID--------",
    "apk-install": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "apk": "cd android && ./gradlew assembleDebug && cd ..",
    "apk-release": "cd android && ./gradlew assembleRelease && cd ..",
    "release-ios-ipa": "APP_ENV=production EXPO_NO_DOTENV=1 npx eas build --profile adhoc --platform ios",
    "release-android-apk": "pnpm cglad && pnpm apk-release && pnpm apk-install",
    "release-android-apk-fast": "pnpm apk-release && pnpm apk-install",
    "build": "pnpm android --variant release",
    "builds": "cross-env EXPO_NO_DOTENV=1 expo run:android --variant release",
    "bundle": "cd android && cross-env APP_ENV=development ./gradlew bundleRelease",
    "publish:android": "npx eas submit --platform android",
    "--------IOS--------": "--------IOS--------",
    "build-ios": "APP_ENV=production npx eas build --platform ios --local",
    "builds-ios": "cross-env APP_ENV=production EXPO_NO_DOTENV=1 expo run:ios --configuration Release -d",
    "ipa:release": "APP_ENV=production EXPO_NO_DOTENV=1 npx eas build --profile adhoc --platform ios --local",
    "publish:ios": "npx eas submit --platform ios",
    "ios:local-ipa": "APP_ENV=production EXPO_NO_DOTENV=1 npx eas build --profile adhoc --platform ios --local",
    "-----------------": "-----------------",
    "start:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview pnpm run start",
    "prebuild:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview STRICT_ENV_VALIDATION=1 pnpm run prebuild",
    "prebuild:development": "cross-env EXPO_PUBLIC_APP_ENV=development STRICT_ENV_VALIDATION=1 pnpm run prebuild",
    "android:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview pnpm run android",
    "ios:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview pnpm run ios",
    "start:production": "cross-env EXPO_PUBLIC_APP_ENV=production pnpm run start",
    "prebuild:production": "cross-env EXPO_PUBLIC_APP_ENV=production STRICT_ENV_VALIDATION=1 pnpm run prebuild",
    "android:production": "cross-env EXPO_PUBLIC_APP_ENV=production pnpm run android",
    "ios:production": "cross-env EXPO_PUBLIC_APP_ENV=production pnpm run ios",
    "build:development:ios": "eas build --profile development --platform ios",
    "build:development:android": "eas build --profile development --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:production:ios": "eas build --profile production --platform ios",
    "build:production:android": "eas build --profile production --platform android",
    "prepare": "husky",
    "app-release": "cross-env SKIP_BRANCH_PROTECTION=true np --no-publish --no-cleanup --no-release-draft",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noemit",
    "lint:translations": "eslint ./src/translations/ --fix --ext .json",
    "test": "jest",
    "check-all": "pnpm run lint && pnpm run type-check && pnpm run lint:translations && pnpm run test",
    "test:ci": "pnpm run test --coverage",
    "test:watch": "pnpm run test --watch",
    "install-maestro": "curl -Ls 'https://get.maestro.mobile.dev' | bash",
    "e2e-test": "maestro test .maestro/ -e APP_ID=com.futurus.development"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "^6.1.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/drawer": "^7.5.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-form": "^1.27.7",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "app-icon-badge": "^0.1.2",
    "axios": "^1.13.2",
    "expo": "~54.0.32",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "^15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.22",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "i18next": "^25.8.0",
    "lodash.memoize": "^4.1.2",
    "lucide-react-native": "^0.546.0",
    "moti": "^0.30.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-error-boundary": "^6.1.0",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^16.5.3",
    "react-native": "0.81.5",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-flash-message": "^0.4.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "^1.18.5",
    "react-native-mmkv": "~4.1.1",
    "react-native-nitro-modules": "^0.33.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.6",
    "react-native-restart": "0.0.27",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "^4.16.0",
    "react-native-svg": "~15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "^0.7.2",
    "react-query-kit": "^3.3.2",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "uniwind": "^1.2.4",
    "zod": "^4.3.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.2.0",
    "@babel/core": "^7.28.6",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@dev-plugins/react-query": "^0.4.0",
    "@eslint-react/eslint-plugin": "^2.7.2",
    "@expo/config": "~12.0.13",
    "@tailwindcss/cli": "^4.0.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/i18n-js": "^4.0.1",
    "@types/invariant": "^2.2.37",
    "@types/jest": "^29.5.14",
    "@types/lodash.memoize": "^4.1.9",
    "@types/react": "~19.1.17",
    "babel-plugin-module-resolver": "^5.0.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-better-tailwindcss": "^4.0.1",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-testing-library": "^7.15.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.16",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.2.7",
    "np": "^10.3.0",
    "tailwindcss": "4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-restart"
        ]
      }
    },
    "install": {
      "exclude": [
        "react-native-worklets"
      ]
    }
  },
  "pnpm": {
    "patchedDependencies": {
      "expo-router@6.0.23": "patches/expo-router@6.0.23.patch"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
