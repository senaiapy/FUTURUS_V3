<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# ============================================
# SECURITY HARDENING (Pentest Fixes)
# ============================================

# Block access to sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(env|env\.example|env\.local|env\.production|gitignore|gitattributes|editorconfig|htaccess)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(sql|sql\.gz|log|lock|json|yml|yaml|xml|md|txt|sh|bak|swp|old)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block composer files
<FilesMatch "^(composer\.(json|lock)|package\.(json|lock)|artisan|phpunit\.xml|webpack\.mix\.js)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to install directory (CRITICAL - Pentest Finding #1)
<IfModule mod_rewrite.c>
    RewriteRule ^install(/.*)?$ - [F,L]
</IfModule>

# Block access to core directory sensitive paths
<IfModule mod_rewrite.c>
    RewriteRule ^core/\.env$ - [F,L]
    RewriteRule ^core/artisan$ - [F,L]
    RewriteRule ^core/composer\.(json|lock)$ - [F,L]
    RewriteRule ^core/package\.(json|lock)$ - [F,L]
    RewriteRule ^core/phpunit\.xml$ - [F,L]
    RewriteRule ^core/storage/logs/.*$ - [F,L]
    RewriteRule ^core/storage/framework/sessions/.*$ - [F,L]
    RewriteRule ^core/storage/framework/cache/.*$ - [F,L]
    RewriteRule ^core/config/.*\.php$ - [F,L]
    RewriteRule ^core/database/.*$ - [F,L]
    RewriteRule ^core/routes/.*$ - [F,L]
    RewriteRule ^core/bootstrap/.*$ - [F,L]
</IfModule>

# Block Docker files
<IfModule mod_rewrite.c>
    RewriteRule ^docker-compose.*\.yml$ - [F,L]
    RewriteRule ^Dockerfile.*$ - [F,L]
</IfModule>

# Security Headers (Pentest Finding #5, #6)
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # XSS Protection (deprecated but kept for older browsers)
    # Modern browsers rely on CSP instead
    Header always set X-XSS-Protection "0"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Content Security Policy (hardened - removed unsafe-eval where possible)
    # Note: 'unsafe-inline' kept for styles due to inline CSS requirements
    # Firebase and Google APIs added for push notifications
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com https://www.gstatic.com https://*.firebaseio.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: https: blob:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://firebaseinstallations.googleapis.com; frame-ancestors 'self';"

    # Permissions Policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Remove server info
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# Disable directory listing
Options -Indexes

# Prevent access to backup files
<FilesMatch "(\.(bak|backup|old|orig|original|save|tmp|temp)|~)$">
    Order allow,deny
    Deny from all
</FilesMatch>
